
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Standard user/patient profile.",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "nickname": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "psychologist", "admin"] },
        "isAnonymous": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Psychologist": {
      "title": "Psychologist",
      "type": "object",
      "description": "Licensed psychologist profile.",
      "properties": {
        "uid": { "type": "string" },
        "licenseNumber": { "type": "string" },
        "specialization": { "type": "array", "items": { "type": "string" } },
        "experienceYears": { "type": "number" },
        "languages": { "type": "array", "items": { "type": "string" } },
        "pricePerSession": { "type": "number" },
        "rating": { "type": "number" },
        "availabilitySlots": { "type": "array", "items": { "type": "string" } },
        "bio": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isApproved": { "type": "boolean" }
      },
      "required": ["uid", "licenseNumber", "specialization", "experienceYears", "pricePerSession"]
    },
    "MoodLog": {
      "title": "MoodLog",
      "type": "object",
      "description": "Daily user mood record.",
      "properties": {
        "userId": { "type": "string" },
        "mood": { "type": "string", "enum": ["Happy", "Calm", "Neutral", "Stressed", "Anxious", "Sad"] },
        "note": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Session": {
      "title": "Session",
      "type": "object",
      "description": "Consultation session record.",
      "properties": {
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "psychologistId": { "type": "string" },
        "psychologistName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "meetingLink": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AIChatLog": {
      "title": "AIChatLog",
      "type": "object",
      "description": "Log for AI support chat.",
      "properties": {
        "chatId": { "type": "string" },
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "ai"] },
        "detectedEmotion": { "type": "string" },
        "riskLevel": { "type": "string", "enum": ["low", "moderate", "high", "critical"] },
        "riskScore": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "In-app notification.",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "readStatus": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "RiskAlert": {
      "title": "RiskAlert",
      "type": "object",
      "description": "Critical emotional risk events.",
      "properties": {
        "userId": { "type": "string" },
        "riskLevel": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      }
    },
    "Resource": {
      "title": "Resource",
      "type": "object",
      "description": "Self-help article or exercise.",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{uid}", "definition": { "entityName": "UserProfile" } },
      { "path": "/psychologists/{uid}", "definition": { "entityName": "Psychologist" } },
      { "path": "/sessions/{sessionId}", "definition": { "entityName": "Session" } },
      { "path": "/ai_chat_logs/{chatId}", "definition": { "entityName": "AIChatLog" } },
      { "path": "/mood_logs/{logId}", "definition": { "entityName": "MoodLog" } },
      { "path": "/notifications/{notificationId}", "definition": { "entityName": "Notification" } },
      { "path": "/risk_alerts/{alertId}", "definition": { "entityName": "RiskAlert" } },
      { "path": "/resources/{resourceId}", "definition": { "entityName": "Resource" } },
      { "path": "/roles_admin/{uid}", "definition": { "description": "Admin access lookup" } }
    ]
  }
}
